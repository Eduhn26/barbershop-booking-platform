generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  client
  stylist
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
}

model Salon {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  primaryColor String?  // ex: "#C68F2E"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
  services     Service[]
  appointments Appointment[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(client)
  avatarUrl String?

  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  // relations for appointments
  clientAppointments  Appointment[] @relation("ClientAppointments")
  stylistAppointments Appointment[] @relation("StylistAppointments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id              String   @id @default(cuid())
  name            String
  priceCents      Int
  durationMinutes Int

  salonId         String
  salon           Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointments    Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id        String            @id @default(cuid())
  salonId   String
  salon     Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)

  clientId  String
  client    User              @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)

  stylistId String
  stylist   User              @relation("StylistAppointments", fields: [stylistId], references: [id], onDelete: Cascade)

  // agendamento
  date      String            // YYYY-MM-DD
  time      String            // HH:mm
  status    AppointmentStatus @default(pending)

  // serviço
  serviceId String
  service   Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  serviceNameSnapshot            String
  servicePriceCentsSnapshot      Int
  serviceDurationMinutesSnapshot Int

  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, stylistId, date, time])
  @@unique([salonId, stylistId, date, time], name: "uniq_stylist_slot")
}
